---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArchiveWindow from '../components/organisms/ArchiveWindow.astro';

// Get the welcome content
const welcomeEntry = await getEntry('cheatsheets', 'welcome');
if (!welcomeEntry) {
    return Astro.redirect('/404');
}

const { Content } = await render(welcomeEntry);
---

<BaseLayout 
    title={welcomeEntry.data.title || welcomeEntry.id}
    slug={welcomeEntry.id}
>
    <ArchiveWindow 
        title={welcomeEntry.data.title || welcomeEntry.id} 
        version={welcomeEntry.data.version}
        breadcrumbs={[{ name: 'Home', href: '/' }, { name: 'Welcome', href: '/' }]}
    >
        <Content />
    </ArchiveWindow>
</BaseLayout>
