---
import BaseLayout from '../layouts/BaseLayout.astro';
import FloatingButtons from '../components/FloatingButtons.astro';
import MetadataSidebar from '../components/MetadataSidebar.astro';
import Legend from '../components/Legend.astro';
import { getCollection, getEntry, render } from 'astro:content';

const welcomeEntry = await getEntry('cheatsheets', 'welcome');
let Content = null;
if (welcomeEntry) {
    const rendered = await render(welcomeEntry);
    Content = rendered.Content;
}

const allCheatsheets = await getCollection('cheatsheets');

const searchData = allCheatsheets.map(post => ({
    title: post.data.title || post.id.replace(/\.mdx?$/, ''),
    slug: post.id.replace(/\.mdx?$/, ''),
    icon: post.data.icon || '📄'
}));
---

<BaseLayout 
    title="Portal de Archivo" 
    searchData={searchData}
>
    <MetadataSidebar 
        slot="metadata" 
        title={welcomeEntry?.data?.title}
        created={welcomeEntry?.data?.created}
        updated={welcomeEntry?.data?.updated}
        tags={['Welcome', 'Executive', 'Archive']}
    />

    <article class="executive-summary">
        {Content ? <Content /> : (
            <div class="empty-state">
                <h2>No se encontró el archivo de bienvenida</h2>
                <p>Por favor crea <code>src/content/cheatsheets/welcome.mdx</code></p>
            </div>
        )}

        <Legend />
    </article>
    
    <FloatingButtons slot="fab" />
</BaseLayout>

<style is:global>
    .executive-summary h1 {
        font-size: 2.8rem;
        font-weight: 800;
        margin-top: 0;
        color: var(--color-primary-dark);
        border-bottom: 4px solid var(--color-primary);
        padding-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .executive-summary h2 {
        font-size: 1.8rem;
        color: #1a1a1a;
        margin-top: 2.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .executive-summary p {
        font-size: 1.1rem;
        line-height: 1.7;
        color: #334155;
    }

    .executive-summary ul {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        padding: 0;
        margin: 2rem 0;
    }

    .executive-summary li {
        background: #fff;
        border: 1px solid #e2e8f0;
        padding: 1.5rem;
        border-radius: var(--radius-md);
        box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        transition: transform 0.2s;
    }

    .executive-summary li:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px rgba(0,0,0,0.05);
        border-color: var(--color-primary-light);
    }

    .executive-summary li::before {
        display: none; /* Hide the global bullet point */
    }

    .executive-summary table {
        width: 100%;
        border-collapse: collapse;
        margin: 2rem 0;
        border-radius: 8px;
        overflow: hidden;
        border: 1px solid var(--color-metal-border);
    }

    .executive-summary th {
        background: var(--texture-metal);
        padding: 12px;
        text-align: left;
        font-weight: 800;
        color: #333;
    }

    .executive-summary td {
        padding: 12px;
        border-bottom: 1px solid #eee;
        background: #fff;
    }
</style>
