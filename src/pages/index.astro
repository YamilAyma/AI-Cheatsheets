---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCheatsheets = await getCollection('cheatsheets');

// Get root directories (first level folders)
const rootCategories = [...new Set(allCheatsheets.map(post => {
    const slug = post.id.replace(/\.mdx?$/, '');
    return slug.split('/')[0];
}).filter(part => part !== ""))].sort();

// Files in the root
const rootFiles = allCheatsheets
    .map(post => ({ ...post, slug: post.id.replace(/\.mdx?$/, '') }))
    .filter(post => !post.slug.includes('/'))
    .sort((a, b) => (a.data.title || '').localeCompare(b.data.title || ''));

const searchData = allCheatsheets.map(post => ({
    title: post.data.title || post.id.replace(/\.mdx?$/, ''),
    slug: post.id.replace(/\.mdx?$/, ''),
    icon: post.data.icon || '📄'
}));
---

<BaseLayout title="Inicio" searchData={searchData}>
    <div class="hero">
        <h2>Antes de aprender, explora estas guías rápidas</h2>
        <p>Resúmenes e información servida para desarrolladores. Explora las categorías para empezar.</p>
    </div>

    <ul class="file-list">
        {rootCategories.map(cat => (
            <li>
                <a href={`/${cat}`} class="folder">
                    <div class="list-icon"></div>
                    <div class="list-content">
                        <span class="list-title">{cat}</span>
                        <span class="list-meta">Categoría</span>
                    </div>
                </a>
            </li>
        ))}
        {rootFiles.map(file => (
            <li>
                <a href={`/${file.slug}`} class="file">
                    <div class="list-icon">{file.data.icon || '📄'}</div>
                    <div class="list-content">
                        <span class="list-title">{file.data.title}</span>
                        <span class="list-meta">
                            {file.data.updatedAt && <span>📅 {file.data.updatedAt}</span>}
                            {file.data.tags && <span>🏷️ {Array.isArray(file.data.tags) ? file.data.tags.join(', ') : file.data.tags}</span>}
                        </span>
                    </div>
                </a>
            </li>
        ))}
    </ul>
</BaseLayout>
