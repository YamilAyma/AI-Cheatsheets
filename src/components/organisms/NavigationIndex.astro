---
import SidebarItem from '../molecules/SidebarItem.astro';
import AquaIcon from '../atoms/AquaIcon.astro';
import { getCollection } from 'astro:content';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

// Fetch all cheatsheets
const allCheatsheets = await getCollection('cheatsheets');
const totalSheets = allCheatsheets.length;

// Build a recursive tree structure from flat paths
interface TreeNode {
  name: string;
  path: string;
  children: Map<string, TreeNode>;
  files: { id: string; title: string }[];
}

function buildTree(entries: any[]): Map<string, TreeNode> {
  const root = new Map<string, TreeNode>();
  
  for (const entry of entries) {
    const parts = entry.id.split('/');
    const fileName = parts.pop()!; // last part is the file
    let current = root;
    let pathSoFar = '';
    
    for (const folder of parts) {
      pathSoFar = pathSoFar ? `${pathSoFar}/${folder}` : folder;
      if (!current.has(folder)) {
        current.set(folder, {
          name: folder,
          path: pathSoFar,
          children: new Map(),
          files: [],
        });
      }
      current = current.get(folder)!.children;
    }
    
    // If no folders, put in a "root" bucket — but typically all have at least one folder
    // The file belongs to the deepest folder in `parts`
    // We need to get the parent node to add the file
    let parent = root;
    let parentNode: TreeNode | null = null;
    let pSoFar = '';
    for (const folder of entry.id.split('/').slice(0, -1)) {
      pSoFar = pSoFar ? `${pSoFar}/${folder}` : folder;
      parentNode = parent.get(folder)!;
      parent = parentNode.children;
    }
    
    if (parentNode) {
      parentNode.files.push({
        id: entry.id,
        title: entry.data.title || fileName,
      });
    }
  }
  
  return root;
}

const tree = buildTree(allCheatsheets);

// Check if a path is an ancestor of the current slug
function isAncestor(folderPath: string, slug?: string): boolean {
  if (!slug) return false;
  return slug.startsWith(folderPath + '/');
}

// Format folder names: replace _ with space, capitalize
function formatName(name: string): string {
  return name.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
}
---
<nav class="navigation-index" aria-label="Cheatsheet navigation">
  <div class="index-meta">
    {totalSheets} items
  </div>
  
  <div class="tree-scroll">
    {[...tree.entries()].sort(([a], [b]) => a.localeCompare(b)).map(([key, node]) => (
      <details class="folder-group" open={isAncestor(node.path, currentSlug)}>
        <summary class="folder-summary">
          <div class="folder-icon-wrapper">
            <span class="icon-closed"><AquaIcon name="folder-closed" class="folder-icon" /></span>
            <span class="icon-open"><AquaIcon name="folder-open" class="folder-icon" /></span>
          </div>
          <span class="folder-name">{formatName(key)}</span>
          <span class="folder-count">{node.files.length + [...node.children.values()].reduce((acc, c) => acc + c.files.length, 0)}</span>
          <div class="chevron-wrapper">
            <span class="chevron-right"><AquaIcon name="arrow-right" class="chevron" /></span>
            <span class="chevron-down"><AquaIcon name="arrow-down" class="chevron" /></span>
          </div>
        </summary>
        <div class="folder-contents">
          {/* Render files at this level */}
          {node.files.map(file => (
            <SidebarItem 
              title={file.title} 
              type="file" 
              href={`/${file.id}`}
              isActive={currentSlug === file.id}
            />
          ))}
          {/* Render sub-folders recursively using a nested fragment */}
          {[...node.children.entries()].sort(([a], [b]) => a.localeCompare(b)).map(([subKey, subNode]) => (
            <details class="folder-group nested" open={isAncestor(subNode.path, currentSlug)}>
              <summary class="folder-summary sub">
                <div class="folder-icon-wrapper">
                  <span class="icon-closed"><AquaIcon name="folder-closed" class="folder-icon" /></span>
                  <span class="icon-open"><AquaIcon name="folder-open" class="folder-icon" /></span>
                </div>
                <span class="folder-name">{formatName(subKey)}</span>
                <span class="folder-count">{subNode.files.length + [...subNode.children.values()].reduce((acc, c) => acc + c.files.length, 0)}</span>
                <div class="chevron-wrapper">
                  <span class="chevron-right"><AquaIcon name="arrow-right" class="chevron" /></span>
                  <span class="chevron-down"><AquaIcon name="arrow-down" class="chevron" /></span>
                </div>
              </summary>
              <div class="folder-contents">
                {subNode.files.map(file => (
                  <SidebarItem 
                    title={file.title} 
                    type="file" 
                    href={`/${file.id}`}
                    isActive={currentSlug === file.id}
                  />
                ))}
                {/* Level 3 sub-folders */}
                {[...subNode.children.entries()].sort(([a], [b]) => a.localeCompare(b)).map(([l3Key, l3Node]) => (
                  <details class="folder-group nested" open={isAncestor(l3Node.path, currentSlug)}>
                    <summary class="folder-summary sub">
                      <div class="folder-icon-wrapper">
                        <span class="icon-closed"><AquaIcon name="folder-closed" class="folder-icon" /></span>
                        <span class="icon-open"><AquaIcon name="folder-open" class="folder-icon" /></span>
                      </div>
                      <span class="folder-name">{formatName(l3Key)}</span>
                      <span class="folder-count">{l3Node.files.length + [...l3Node.children.values()].reduce((acc, acc2) => acc + acc2.files.length, 0)}</span>
                      <div class="chevron-wrapper">
                        <span class="chevron-right"><AquaIcon name="arrow-right" class="chevron" /></span>
                        <span class="chevron-down"><AquaIcon name="arrow-down" class="chevron" /></span>
                      </div>
                    </summary>
                    <div class="folder-contents">
                      {l3Node.files.map(file => (
                        <SidebarItem 
                          title={file.title} 
                          type="file" 
                          href={`/${file.id}`}
                          isActive={currentSlug === file.id}
                        />
                      ))}
                      {/* Level 4 sub-folders */}
                      {[...l3Node.children.entries()].sort(([a], [b]) => a.localeCompare(b)).map(([l4Key, l4Node]) => (
                        <details class="folder-group nested" open={isAncestor(l4Node.path, currentSlug)}>
                          <summary class="folder-summary sub">
                            <div class="folder-icon-wrapper">
                              <span class="icon-closed"><AquaIcon name="folder-closed" class="folder-icon" /></span>
                              <span class="icon-open"><AquaIcon name="folder-open" class="folder-icon" /></span>
                            </div>
                            <span class="folder-name">{formatName(l4Key)}</span>
                            <span class="folder-count">{l4Node.files.length}</span>
                            <div class="chevron-wrapper">
                              <span class="chevron-right"><AquaIcon name="arrow-right" class="chevron" /></span>
                              <span class="chevron-down"><AquaIcon name="arrow-down" class="chevron" /></span>
                            </div>
                          </summary>
                          <div class="folder-contents">
                            {l4Node.files.map(file => (
                              <SidebarItem 
                                title={file.title} 
                                type="file" 
                                href={`/${file.id}`}
                                isActive={currentSlug === file.id}
                              />
                            ))}
                          </div>
                        </details>
                      ))}
                    </div>
                  </details>
                ))}
              </div>
            </details>
          ))}
        </div>
      </details>
    ))}
  </div>
</nav>

<style>
  .navigation-index {
    display: flex;
    flex-direction: column;
  }

  .index-meta {
    font-size: 0.72rem;
    font-weight: 700;
    color: #94a3b8;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #e2e8f0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .tree-scroll {
    padding-right: 4px;
    padding-bottom: 20px;
  }

  .folder-group {
    margin-bottom: 2px;
  }

  .folder-group.nested {
    margin-left: 8px;
    padding-left: 10px;
    border-left: 1px solid #e2e8f0;
    margin-top: 2px;
  }

  summary {
    list-style: none;
    outline: none;
    cursor: pointer;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .folder-summary {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 5px 8px;
    border-radius: 4px;
    font-size: 0.82rem;
    font-weight: 600;
    color: #334155;
    transition: background 0.15s;
    user-select: none;
  }

  .folder-summary:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .folder-summary.sub {
    font-size: 0.78rem;
    font-weight: 500;
    color: #64748b;
    padding: 4px 6px;
  }

  /* Default states (Closed) */
  .icon-open, .chevron-down {
    display: none !important;
  }

  /* Open states (triggered by details[open]) */
  .folder-group[open] > summary .icon-closed {
    display: none !important;
  }
  .folder-group[open] > summary .icon-open {
    display: flex !important;
  }

  .folder-group[open] > summary .chevron-right {
    display: none !important;
  }
  .folder-group[open] > summary .chevron-down {
    display: flex !important;
  }

  .folder-icon-wrapper, .chevron-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .folder-icon {
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .folder-name {
    flex: 1;
    white-space: nowrap;
  }

  .folder-count {
    font-size: 0.68rem;
    font-weight: 700;
    color: #94a3b8;
    background: #f1f5f9;
    padding: 1px 5px;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .chevron {
    font-size: 0.65rem;
    color: #94a3b8;
    flex-shrink: 0;
  }

  .folder-contents {
    margin-top: 2px;
    display: flex;
    flex-direction: column;
    gap: 1px;
    padding-bottom: 4px;
  }

  /* Indent files under folders */
  .folder-contents :global(.sidebar-item) {
    margin-left: 20px;
  }

  .folder-contents .folder-group.nested :global(.sidebar-item) {
    margin-left: 12px;
  }
</style>
