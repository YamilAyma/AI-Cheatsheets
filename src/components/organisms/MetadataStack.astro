---
import SidebarCard from '../molecules/SidebarCard.astro';
import Icon from '../atoms/Icon.astro';

interface Props {
  author?: string;
  version?: string;
  updated?: string;
  tags?: string[];
}

const { author = "System", version = "1.0", updated = "2024", tags = [] } = Astro.props;
---
<aside class="metadata-stack">
  <SidebarCard title="ACTIONS">
    <div class="action-list">
      <button class="action-btn">
        <Icon name="⭐" /> Add to Favorites
      </button>
      <button class="action-btn">
        <Icon name="🚩" /> Report Issue
      </button>
      <button class="action-btn">
        <Icon name="✏️" /> Suggest Edit
      </button>
    </div>
  </SidebarCard>

  <SidebarCard title="DOWNLOADS">
    <div class="download-list">
      <div class="download-item">
        <div class="file-type txt">TXT</div>
        <div class="file-info">
           <span class="file-name">Plain Text Archive</span>
           <span class="file-meta">ASCII Format • 12KB</span>
        </div>
      </div>
      <div class="download-item">
        <div class="file-type pdf">PDF</div>
        <div class="file-info">
           <span class="file-name">Standard Print PDF</span>
           <span class="file-meta">Vector Graphics • 1.2MB</span>
        </div>
      </div>
    </div>
  </SidebarCard>

  <SidebarCard title="DETAILS">
     <div class="detail-grid">
        <div class="detail-row">
            <span class="label">AUTHOR:</span>
            <span class="value">{author}</span>
        </div>
        <div class="detail-row">
            <span class="label">VERSION:</span>
            <span class="value">{version}</span>
        </div>
        <div class="detail-row">
            <span class="label">UPDATED:</span>
            <span class="value">{updated}</span>
        </div>
     </div>
  </SidebarCard>
</aside>

<style>
.metadata-stack {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.action-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.action-btn {
    display: flex;
    align-items: center;
    gap: 12px;
    background: white;
    border: 1px solid #ddd;
    padding: 8px 15px;
    border-radius: var(--rounded-md);
    font-size: 0.85rem;
    font-weight: 700;
    color: #334155;
    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
}

.action-btn:hover {
    border-color: var(--color-primary);
    background: #f0f7ff;
}

.download-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.download-item {
    display: flex;
    gap: 12px;
    align-items: center;
    padding: 8px;
    background: white;
    border: 1px solid #ddd;
    border-radius: var(--rounded-md);
}

.file-type {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 900;
    color: white;
    border-radius: 4px;
}

.file-type.txt { background: #64748b; }
.file-type.pdf { background: #ef4444; }

.file-name {
    display: block;
    font-size: 0.85rem;
    font-weight: 800;
    color: #1e293b;
}

.file-meta {
    font-size: 0.7rem;
    color: #64748b;
}

.detail-grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.detail-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    padding-bottom: 4px;
    border-bottom: 1px solid #eee;
}

.label {
    font-weight: 900;
    color: #64748b;
}

.value {
    font-weight: 700;
    color: #1e293b;
}
</style>
