---
import Badge from "../atoms/Badge.astro";

interface Props {
  title: string;
  version?: string;
  breadcrumbs?: { name: string; href: string }[];
  class?: string;
}

const {
  title,
  version = "v1.0.0",
  breadcrumbs = [],
  class: className,
} = Astro.props;
---

<div class:list={["archive-window", className]}>
  <div class="window-header">
    <div class="window-controls">
      <span class="control close"></span>
      <span class="control minimize"></span>
      <span class="control maximize"></span>
    </div>
  </div>

  <div class="window-content">
    <!-- Meta Header -->
    <div class="meta-header">
      <nav class="meta-breadcrumbs">
        {
          breadcrumbs.map((crumb, index) => (
            <>
              <a href={crumb.href}>{crumb.name}</a>
              {index < breadcrumbs.length - 1 && (
                <span class="meta-sep"> &gt; </span>
              )}
            </>
          ))
        }
      </nav>

      <div class="header-main-row">
        <span class="header-version">{version}</span>

        <div
          class="header-actions"
          data-title={title}
          data-path={Astro.url.pathname}
        >
          <button class="header-action" id="btn-favorite">
            <span class="icon">⭐</span>
            <span class="btn-text">Añadir a Favoritos</span>
          </button>
          <button class="header-action" id="btn-print">
            <span class="icon">🖨️</span> Imprimir
          </button>
          <button class="header-action" id="btn-download">
            <span class="icon">📄</span> Descargar MD
          </button>
        </div>
      </div>

      <hr class="header-divider" />
    </div>

    <div class="content-body" id="cheatsheet-content">
      <slot />
    </div>
  </div>

  <!-- Aqua Style Notification -->
  <div id="aqua-notification" class="aqua-notification">
    <div class="notif-content">
      <span class="notif-icon"></span>
      <span class="notif-message">Descarga completada</span>
    </div>
  </div>
</div>

<script>
  const btnFavorite = document.getElementById("btn-favorite");
  const btnPrint = document.getElementById("btn-print");
  const btnDownload = document.getElementById("btn-download");
  const notification = document.getElementById("aqua-notification");

  const actionsContainer = document.querySelector(".header-actions");
  const pageTitle = actionsContainer?.getAttribute("data-title");
  const pagePath = actionsContainer?.getAttribute("data-path");

  // --- Favorites Logic ---
  function updateFavoriteButton() {
    if (!btnFavorite || !pagePath) return;
    const favorites = JSON.parse(
      localStorage.getItem("ai-cheatsheets-favorites") || "[]",
    );
    const isFav = favorites.some((f) => f.path === pagePath);

    const btnText = btnFavorite.querySelector(".btn-text");
    if (btnText) {
      btnText.textContent = isFav
        ? "Quitar de Favoritos"
        : "Añadir a Favoritos";
    }
    btnFavorite.classList.toggle("is-fav", isFav);
  }

  btnFavorite?.addEventListener("click", () => {
    const favorites = JSON.parse(
      localStorage.getItem("ai-cheatsheets-favorites") || "[]",
    );
    const index = favorites.findIndex((f) => f.path === pagePath);

    if (index > -1) {
      favorites.splice(index, 1);
    } else {
      favorites.push({ title: pageTitle, path: pagePath });
    }

    localStorage.setItem("ai-cheatsheets-favorites", JSON.stringify(favorites));
    updateFavoriteButton();
  });

  // --- Print Logic ---
  btnPrint?.addEventListener("click", () => {
    window.print();
  });

  // --- Download Logic ---
  btnDownload?.addEventListener("click", () => {
    const content = document.getElementById("cheatsheet-content");
    if (!content) return;

    const text = content.innerText;
    const blob = new Blob([`# ${pageTitle}\n\n${text}`], {
      type: "text/markdown",
    });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");

    const fileName = (pageTitle || "cheatsheet")
      .toLowerCase()
      .replace(/\s+/g, "-");
    a.href = url;
    a.download = `${fileName}.md`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);

    // Show Aqua Notification
    if (notification) {
      notification.classList.add("show");
      setTimeout(() => {
        notification.classList.remove("show");
      }, 3000);
    }
  });

  // Initialize
  updateFavoriteButton();
</script>

<style>
  .archive-window {
    background: #fff;
    border: 1px solid #999;
    border-radius: 8px;
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.15),
      0 1px 2px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 600px;
    position: relative;
  }

  .window-header {
    background: var(--texture-metal);
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 15px;
    border-bottom: 1px solid #999;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    position: relative;
  }

  .window-controls {
    display: flex;
    gap: 8px;
    position: absolute;
    left: 15px;
  }

  .control {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 0.5px solid rgba(0, 0, 0, 0.3);
    position: relative;
    box-shadow:
      inset 0 1px 1px rgba(0, 0, 0, 0.1),
      0 0.5px 0.5px rgba(255, 255, 255, 0.4);
  }

  .control::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 8px;
    height: 4px;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.8) 0%,
      rgba(255, 255, 255, 0.1) 100%
    );
    border-radius: 4px 4px 2px 2px;
  }

  .control.close {
    background: linear-gradient(to bottom, #ff7b73 0%, #ff5f56 100%);
  }
  .control.minimize {
    background: linear-gradient(to bottom, #ffce52 0%, #ffbd2e 100%);
  }
  .control.maximize {
    background: linear-gradient(to bottom, #30e04f 0%, #27c93f 100%);
  }

  .window-content {
    flex: 1;
    padding: 40px;
    overflow-y: auto;
  }

  /* Meta Header Styles */
  .meta-header {
    margin-bottom: 30px;
  }

  .meta-breadcrumbs {
    font-size: 0.75rem;
    color: #2563eb;
    margin-bottom: 10px;
  }

  .meta-breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .meta-breadcrumbs a:hover {
    text-decoration: underline;
  }

  .meta-sep {
    color: #94a3b8;
  }

  .header-main-row {
    display: flex;
    align-items: center;
    gap: 15px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .header-version {
    font-size: 0.85rem;
    color: #64748b;
    font-weight: 600;
  }

  .header-actions {
    display: flex;
    gap: 15px;
    margin-left: auto;
  }

  .header-action {
    background: none;
    border: none;
    color: #2563eb;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0;
    transition: all 0.2s;
  }

  .header-action:hover {
    text-decoration: underline;
  }

  .header-action.is-fav {
    color: #eab308;
  }

  .header-divider {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 0;
  }

  .content-body {
    font-size: 1rem;
    line-height: 1.6;
    color: #334155;
  }

  /* Aqua Notification Styles */
  .aqua-notification {
    position: absolute;
    bottom: -60px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    transition: bottom 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    pointer-events: none;
  }

  .aqua-notification.show {
    bottom: 20px;
  }

  .notif-content {
    background: var(--texture-aqua);
    color: white;
    padding: 10px 24px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow:
      0 10px 25px rgba(0, 102, 204, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.4);
    border: 1px solid var(--color-primary-dark);
    font-size: 0.85rem;
    font-weight: 700;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
  }

  .notif-icon {
    font-size: 1.1rem;
    background: rgba(255, 255, 255, 0.2);
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }

  @media print {
    .meta-header,
    .aqua-notification {
      display: none !important;
    }
    .window-header {
      display: none !important;
    }
    .archive-window {
      border: none !important;
      box-shadow: none !important;
    }
  }
</style>
