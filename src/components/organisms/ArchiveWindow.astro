---
import Badge from '../atoms/Badge.astro';

interface Props {
  title: string;
  version?: string;
  breadcrumbs?: { name: string; href: string }[];
  class?: string;
}

const { 
  title, 
  version = "v1.0.0", 
  breadcrumbs = [],
  class: className 
} = Astro.props;
---
<div class:list={['archive-window', className]}>
  <div class="window-header">
    <div class="window-controls">
      <span class="control close"></span>
      <span class="control minimize"></span>
      <span class="control maximize"></span>
    </div>
  </div>
  
  <div class="window-content">
    <!-- Meta Header -->
    <div class="meta-header">
        <nav class="meta-breadcrumbs">
            {breadcrumbs.map((crumb, index) => (
                <>
                    <a href={crumb.href}>{crumb.name}</a>
                    {index < breadcrumbs.length - 1 && <span class="meta-sep"> &gt; </span>}
                </>
            ))}
        </nav>
        
        <div class="header-main-row">
            <span class="header-version">{version}</span>
            
            <div class="header-actions">
                <button class="header-action"><span class="icon">⭐</span> Add to Favorites</button>
                <button class="header-action"><span class="icon">🖨️</span> Print</button>
                <button class="header-action"><span class="icon">📄</span> Download (TXT)</button>
            </div>
        </div>
        
        <hr class="header-divider" />
    </div>
    
    <div class="content-body">
      <slot />
    </div>
  </div>
</div>

<style>
  .archive-window {
    background: #fff;
    border: 1px solid #999;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.15), 0 1px 2px rgba(0,0,0,0.1);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 600px;
  }

  .window-header {
    background: var(--texture-metal);
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 15px;
    border-bottom: 1px solid #999;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.8);
  }

  .window-controls {
    display: flex;
    gap: 8px;
    position: absolute;
    left: 15px;
  }

  .control {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 0.5px solid rgba(0,0,0,0.3);
    position: relative;
    box-shadow: inset 0 1px 1px rgba(0,0,0,0.1), 0 0.5px 0.5px rgba(255,255,255,0.4);
  }

  .control::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 8px;
    height: 4px;
    background: linear-gradient(to bottom, rgba(255,255,255,0.8) 0%, rgba(255,255,255,0.1) 100%);
    border-radius: 4px 4px 2px 2px;
  }

  .control.close { background: linear-gradient(to bottom, #ff7b73 0%, #ff5f56 100%); }
  .control.minimize { background: linear-gradient(to bottom, #ffce52 0%, #ffbd2e 100%); }
  .control.maximize { background: linear-gradient(to bottom, #30e04f 0%, #27c93f 100%); }

  .window-content {
    flex: 1;
    padding: 40px;
    overflow-y: auto;
  }

  /* Meta Header Styles */
  .meta-header {
    margin-bottom: 30px;
  }

  .meta-breadcrumbs {
    font-size: 0.75rem;
    color: #2563eb;
    margin-bottom: 10px;
  }

  .meta-breadcrumbs a {
    color: inherit;
    text-decoration: none;
  }

  .meta-breadcrumbs a:hover {
    text-decoration: underline;
  }

  .meta-sep {
    color: #94a3b8;
  }

  .header-main-row {
    display: flex;
    align-items: center;
    gap: 15px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }

  .header-version {
    font-size: 0.85rem;
    color: #64748b;
    font-weight: 600;
  }

  .header-actions {
    display: flex;
    gap: 15px;
    margin-left: auto;
  }

  .header-action {
    background: none;
    border: none;
    color: #2563eb;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 0;
  }

  .header-action:hover {
    text-decoration: underline;
  }

  .header-divider {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin: 0;
  }

  .content-body {
    font-size: 1rem;
    line-height: 1.6;
    color: #334155;
  }
</style>
