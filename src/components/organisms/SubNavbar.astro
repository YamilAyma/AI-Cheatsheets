---
import { getCollection } from 'astro:content';

const allCheatsheets = await getCollection('cheatsheets');

// Define known languages for categorization
const knownLanguages = ['python', 'javascript', 'typescript', 'php', 'css', 'html', 'sql', 'bash', 'c#', 'java', 'go', 'rust'];

// Dynamic categories from directories (excluding 'welcome' and empty parts)
const categories = [...new Set(allCheatsheets.map(post => {
    const parts = post.id.split('/');
    return parts.length > 1 ? parts[0] : null;
}).filter(Boolean))].sort();

// Extract tags and categorize them
const allTags = [...new Set(allCheatsheets.flatMap(post => post.data.tags || []))].filter(Boolean);

const languages = allTags.filter(tag => knownLanguages.includes(tag.toLowerCase())).sort();
const tools = allTags.filter(tag => !knownLanguages.includes(tag.toLowerCase()) && tag.toLowerCase() !== 'general').sort();
---
<div class="sub-navbar">
    <div class="sub-nav-left">
        <a href="/popular" class="sub-nav-link">Popular</a>
        <a href="/new" class="sub-nav-link">New</a>
        
        <div class="dropdown">
            <button class="dropdown-toggle sub-nav-link">By Category ▾</button>
            <div class="dropdown-menu">
                {categories.map(cat => (
                    <a href={`/${cat}`} class="dropdown-item">
                        {cat.charAt(0).toUpperCase() + cat.slice(1)}
                    </a>
                ))}
            </div>
        </div>

        <div class="dropdown">
            <button class="dropdown-toggle sub-nav-link">By Language ▾</button>
            <div class="dropdown-menu">
                {languages.length > 0 ? languages.map(lang => (
                    <a href={`/search?q=${lang}`} class="dropdown-item">{lang}</a>
                )) : <span class="dropdown-item disabled">No languages found</span>}
            </div>
        </div>

        <div class="dropdown">
            <button class="dropdown-toggle sub-nav-link">By Tool ▾</button>
            <div class="dropdown-menu">
                {tools.length > 0 ? tools.map(tool => (
                    <a href={`/search?q=${tool}`} class="dropdown-item">{tool}</a>
                )) : <span class="dropdown-item disabled">No tools found</span>}
            </div>
        </div>

        <a href="https://github.com/YamilAyma/AI-Cheatsheets" target="_blank" class="sub-nav-link highlight">Submit a Sheet</a>
    </div>

    <div class="sub-nav-right">
        <div class="search-box">
            <input 
                type="text" 
                id="subNavbarSearch" 
                class="search-input"
                placeholder="Search Archive..." 
                autocomplete="off"
            />
            <button class="search-button">SEARCH</button>
        </div>
    </div>
</div>

<style>
.sub-navbar {
        background: #f1f5f9;
        height: 38px;
        border-bottom: 1px solid #cbd5e1;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 20px;
        position: sticky;
        top: 0;
        z-index: 50;
    }

    .sub-nav-left {
        display: flex;
        gap: 15px;
        align-items: center;
        height: 100%;
    }

    .sub-nav-link {
        font-size: 0.72rem;
        color: #475569;
        text-decoration: none;
        font-weight: 800;
        padding: 4px 8px;
        border-radius: 4px;
        transition: all 0.2s;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .sub-nav-link:hover {
        color: var(--color-primary);
        background: rgba(0,0,0,0.03);
    }

    .sub-nav-link.highlight {
        color: var(--color-primary);
        border-bottom: 2px solid var(--color-primary);
        border-radius: 0;
    }

    /* Dropdown Logic */
    .dropdown {
        position: relative;
        height: 100%;
        display: flex;
        align-items: center;
    }

    .dropdown:hover .dropdown-menu {
        display: block;
        animation: slideDown 0.2s ease-out;
    }

    .dropdown-menu {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px) saturate(180%);
        border: 1px solid rgba(0,0,0,0.1);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        border-radius: 0 0 8px 8px;
        padding: 8px 0;
        min-width: 220px;
        z-index: 2000;
        border-top: 2px solid var(--color-primary);
    }

    .dropdown-item {
        display: block;
        padding: 10px 18px;
        color: #1e293b;
        text-decoration: none;
        font-size: 0.7rem;
        transition: all 0.15s;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.02em;
    }

    .dropdown-item:hover {
        background: var(--color-primary);
        color: white;
    }

    .dropdown-item.disabled {
        color: #94a3b8;
        font-style: italic;
        font-size: 0.65rem;
    }

    .dropdown-toggle {
        background: none;
        border: none;
        cursor: pointer;
        font-family: inherit;
    }

    /* Search Console */
    .search-box {
        display: flex;
        align-items: center;
        background: white;
        border: 1px solid #cbd5e1;
        border-radius: 4px;
        padding: 2px;
        box-shadow: inset 0 1px 2px rgba(0,0,0,0.05);
    }

    .search-input {
        border: none;
        padding: 4px 10px;
        font-size: 0.75rem;
        width: 220px;
        outline: none;
        font-weight: 500;
        color: #334155;
    }

    .search-button {
        background: var(--texture-metal);
        border: 1px solid #94a3b8;
        padding: 4px 12px;
        font-size: 0.65rem;
        font-weight: 900;
        color: #334155;
        border-radius: 3px;
        cursor: pointer;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        transition: all 0.2s;
    }

    .search-button:hover {
        filter: brightness(1.1);
        border-color: var(--color-primary);
    }

    @keyframes slideDown {
        from { opacity: 0; transform: translateY(-5px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
