---
---
<footer class="site-footer">
    <div class="footer-container">
        <div class="status-bar-left">
            <span class="system-status">System Ready</span>
            <span class="sep">|</span>
            <span class="copyright">© 2024 AI-Cheatsheets</span>
        </div>
        
        <div class="status-bar-right">
            <div class="footer-links">
                <a href="#">Privacy</a>
                <a href="#">Contact</a>
                <a href="https://github.com/YamilAyma/AI-Cheatsheets">GitHub Source</a>
            </div>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        background: linear-gradient(to bottom, #cbd5e1 0%, #94a3b8 100%);
        border-top: 1px solid #64748b;
        height: 40px;
        display: flex;
        align-items: center;
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.4);
        z-index: 1000;
        position: relative;
    }

    .footer-container {
        width: 100%;
        padding: 0 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .status-bar-left, .status-bar-right {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .system-status {
        font-size: 0.7rem;
        font-weight: 700;
        color: #1e293b;
        text-shadow: 0 1px 0 rgba(255,255,255,0.4);
    }

    .sep {
        color: #64748b;
        font-size: 0.7rem;
    }

    .copyright {
        font-size: 0.65rem;
        color: #334155;
        font-weight: 500;
        text-shadow: 0 1px 0 rgba(255,255,255,0.4);
    }

    .footer-links {
        display: flex;
        gap: 15px;
    }

    .footer-links a {
        color: #1e293b;
        text-decoration: none;
        font-size: 0.65rem;
        font-weight: 700;
        text-shadow: 0 1px 0 rgba(255,255,255,0.4);
    }

    .footer-links a:hover {
        text-decoration: underline;
    }
</style>
