---
---
<footer class="site-footer">
    <div class="footer-container">
        <div class="footer-content">
            <div class="footer-brand">
                <span class="logo-text">Cheatsheets</span>
                <span class="badge">ARCHIVE</span>
            </div>
            <div class="footer-links">
                <a href="#">Terms</a>
                <a href="#">Privacy</a>
                <a href="#">Contact</a>
                <a href="https://github.com/YamilAyma/AI-Cheatsheets">GitHub</a>
            </div>
            <p class="copyright">© 2024 AI-Cheatsheets. Built with Authority.</p>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        background: #f8fafc;
        border-top: 1px solid #cbd5e1;
        padding: 40px 0;
        margin-top: 60px;
    }

    .footer-container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 40px;
    }

    .footer-content {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 15px;
    }

    .footer-brand {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .logo-text {
        font-family: 'Plus Jakarta Sans', sans-serif;
        font-size: 1.1rem;
        font-weight: 800;
        color: #1e293b;
        letter-spacing: -0.02em;
    }

    .badge {
        background: var(--color-primary);
        color: white;
        font-size: 0.55rem;
        font-weight: 900;
        padding: 2px 6px;
        border-radius: 3px;
    }

    .footer-links {
        display: flex;
        gap: 20px;
    }

    .footer-links a {
        color: #64748b;
        text-decoration: none;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: color 0.2s;
    }

    .footer-links a:hover {
        color: var(--color-primary);
    }

    .copyright {
        font-size: 0.65rem;
        color: #94a3b8;
        margin: 0;
        font-weight: 500;
    }
</style>
