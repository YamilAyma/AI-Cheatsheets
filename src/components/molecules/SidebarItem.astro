---
import Icon from '../atoms/Icon.astro';
import Badge from '../atoms/Badge.astro';

interface Props {
  title: string;
  type: 'folder' | 'file';
  count?: number;
  href?: string;
  isActive?: boolean;
  showChevron?: boolean;
}

const { title, type, count, href, isActive, showChevron } = Astro.props;
const icon = type === 'folder' ? '📂' : '📄';
const Tag = href ? 'a' : 'div';
---
<Tag href={href} class:list={['sidebar-item', type, { active: isActive, 'has-chevron': showChevron }]}>
  {showChevron && <span class="chevron">▾</span>}
  <Icon name={icon} class="item-icon" />
  <span class="item-title">{title}</span>
  {count !== undefined && <Badge text={count.toString()} variant="metal" class="item-count" />}
</Tag>

<style>
  .sidebar-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 10px;
    text-decoration: none;
    color: #444;
    font-size: 0.82rem;
    font-weight: 700;
    border-radius: 4px;
    transition: all 0.2s;
    border: 1px solid transparent;
    cursor: pointer;
    user-select: none;
  }

  .chevron {
    font-size: 0.7rem;
    color: #94a3b8;
    transition: transform 0.2s;
    width: 10px;
    display: inline-block;
    text-align: center;
  }

  .sidebar-item:hover {
    background: rgba(0,0,0,0.05);
    border-color: rgba(0,0,0,0.1);
  }

  .sidebar-item.active {
    background: rgba(0, 102, 204, 0.08);
    color: #111;
    border-left: 3px solid var(--color-primary);
    font-weight: 800;
  }

  .sidebar-item.active .item-count {
    background: rgba(0, 102, 204, 0.12);
    border-color: rgba(0, 102, 204, 0.2);
    color: var(--color-primary);
  }

  .item-title {
    flex: 1;
    white-space: nowrap;
  }

  .item-icon {
    font-size: 1rem;
    opacity: 0.8;
  }

  .sidebar-item.active .item-icon {
    opacity: 1;
  }
</style>
