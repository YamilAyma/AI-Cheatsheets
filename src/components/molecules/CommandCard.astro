---
interface Props {
    title: string;
    icon?: string;
}

const { title, icon } = Astro.props;
---
<div class="command-card content-window">
    <div class="card-header">
        {icon && <span class="card-icon">{icon}</span>}
        <h3 class="card-title">{title}</h3>
    </div>
    <div class="card-body">
        <div class="card-inner-header">
            <span class="label">Referencia</span>
            <span class="label">Descripción Ejecutiva</span>
        </div>
        <slot />
    </div>
</div>

<style>
    .command-card {
        background: white;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        margin-bottom: 24px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        overflow: hidden;
        transition: transform 0.2s;
    }

    .command-card:hover {
        transform: translateY(-2px);
    }

    .card-header {
        background: var(--texture-metal);
        padding: 10px 16px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-bottom: 1px solid #cbd5e1;
    }

    .card-icon {
        font-size: 1.2rem;
        filter: drop-shadow(0 1px 1px rgba(0,0,0,0.1));
    }

    .card-title {
        font-size: 0.85rem;
        font-weight: 800;
        margin: 0;
        color: #1e293b;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .card-body {
        padding: 0;
    }

    .card-inner-header {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 15px;
        padding: 8px 16px;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
    }

    .card-inner-header .label {
        font-size: 0.6rem;
        font-weight: 900;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
</style>
