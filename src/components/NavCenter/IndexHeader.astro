---
interface Props {
    total: number;
    showing?: number;
}

const { total, showing = Math.min(20, total) } = Astro.props;
---
<div class="index-meta">
    <span class="counter-label">Showing 1-{showing} of {total} items</span>
</div>

<style>
    .index-meta {
        padding: 5px 0 10px 0;
        border-bottom: 1px solid #eee;
        margin-bottom: 5px;
    }
    
    .counter-label {
        font-size: 0.7rem;
        color: #888;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
</style>
