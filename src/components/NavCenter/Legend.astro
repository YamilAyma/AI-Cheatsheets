---
import SidebarCard from '../Shared/SidebarCard.astro';
---
<SidebarCard title="Legend">
    <div class="legend-grid">
        <div class="legend-item">
            <span class="legend-icon">🏛️</span>
            <span class="legend-label">Main Archive</span>
        </div>
        <div class="legend-item">
            <span class="legend-icon">🤖</span>
            <span class="legend-label">Core AI</span>
        </div>
        <div class="legend-item">
            <span class="legend-icon">🏗️</span>
            <span class="legend-label">Architecture</span>
        </div>
        <div class="legend-item">
            <span class="legend-icon">💻</span>
            <span class="legend-label">Development</span>
        </div>
        <div class="legend-item">
            <span class="legend-icon">🛠️</span>
            <span class="legend-label">Toolkits</span>
        </div>
        <div class="legend-item">
            <span class="legend-icon">📄</span>
            <span class="legend-label">Standard File</span>
        </div>
    </div>
</SidebarCard>

<style>
    .legend-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 0;
    }

    .legend-icon {
        font-size: 1.1rem;
        filter: drop-shadow(0 1px 1px rgba(0,0,0,0.1));
    }

    .legend-label {
        font-size: 0.75rem;
        color: #555;
        font-weight: 600;
    }
</style>
