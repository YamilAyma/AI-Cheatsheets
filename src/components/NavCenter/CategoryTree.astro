---
interface Props {
    sheetsByCategory: {
        name: string;
        sheets: any[];
    }[];
}

const { sheetsByCategory } = Astro.props;
---
<ul class="category-tree">
    {sheetsByCategory.map(group => (
        <li class="category-node">
            <details open>
                <summary class="category-summary">
                    <span class="folder-icon">📂</span>
                    <span class="category-name">{group.name.charAt(0).toUpperCase() + group.name.slice(1)}</span>
                    <span class="count-badge">{group.sheets.length}</span>
                </summary>
                <ul class="file-list">
                    {group.sheets.map(sheet => (
                        <li class="file-node">
                            <a href={`/${sheet.slug}`} class="file-link">
                                <span class="file-icon">📄</span>
                                <span class="file-name">{sheet.data.title || sheet.id.split('/').pop().replace(/\.mdx?$/, '')}</span>
                            </a>
                        </li>
                    ))}
                </ul>
            </details>
        </li>
    ))}
</ul>

<style>
    .category-tree {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .category-node {
        margin-bottom: 2px;
    }

    .category-summary {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        cursor: pointer;
        font-size: 0.85rem;
        font-weight: 700;
        color: #444;
        transition: background 0.2s;
        border-radius: 4px;
        user-select: none;
    }

    .category-summary:hover {
        background: rgba(0,0,0,0.04);
    }

    .category-summary::-webkit-details-marker {
        display: none;
    }

    .folder-icon {
        font-size: 1rem;
        filter: saturate(1.2);
    }

    .category-name {
        flex: 1;
    }

    .count-badge {
        background: #e0e0e0;
        color: #666;
        padding: 1px 6px;
        border-radius: 10px;
        font-size: 0.7rem;
        font-weight: 800;
        box-shadow: inset 0 1px 1px rgba(0,0,0,0.05);
    }

    .file-list {
        list-style: none;
        padding-left: 18px;
        margin: 2px 0 5px 0;
        border-left: 1px solid #eee;
    }

    .file-node {
        margin: 1px 0;
    }

    .file-link {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 4px 10px;
        text-decoration: none;
        color: #666;
        font-size: 0.8rem;
        border-radius: 4px;
        transition: all 0.2s;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .file-link:hover {
        background: #007AFF;
        color: white;
    }

    .file-icon {
        font-size: 0.9rem;
        opacity: 0.8;
    }
</style>
