---
import SidebarCard from '../Shared/SidebarCard.astro';
import IndexHeader from './IndexHeader.astro';
import CategoryTree from './CategoryTree.astro';
import Legend from './Legend.astro';
import { getCollection } from 'astro:content';

interface Props {
    totalSheets: number;
}

const { totalSheets } = Astro.props;

// Fetch and group sheets for the tree
const allCheatsheets = await getCollection('cheatsheets');
const categories = [...new Set(allCheatsheets.map(post => {
    const slug = post.id.replace(/\.mdx?$/, '');
    return slug.split('/')[0];
}).filter(part => part !== "" && part !== 'welcome'))].sort();

const sheetsByCategory = categories.map(cat => ({
    name: cat,
    sheets: allCheatsheets.filter(post => post.id.startsWith(cat)).map(sheet => ({
        ...sheet,
        slug: sheet.id.replace(/\.mdx?$/, '')
    }))
}));
---
<div class="nav-center-organism">
    <!-- PRIMARY INDEX CARD -->
    <SidebarCard title="Index">
        <IndexHeader total={totalSheets} />
        <div class="tree-wrapper">
            <CategoryTree sheetsByCategory={sheetsByCategory} />
        </div>
    </SidebarCard>

    <!-- SYSTEM LEGEND -->
    <Legend />
</div>

<style>
    .nav-center-organism {
        display: flex;
        flex-direction: column;
        gap: 0; /* SidebarCard and Legend already have their own spacing/margins */
    }

    .tree-wrapper {
        padding: 10px 0;
        max-height: 500px;
        overflow-y: auto;
    }

    /* Custom Scrollbar for the Tree */
    .tree-wrapper::-webkit-scrollbar {
        width: 6px;
    }
    .tree-wrapper::-webkit-scrollbar-track {
        background: transparent;
    }
    .tree-wrapper::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 10px;
    }
    .tree-wrapper::-webkit-scrollbar-thumb:hover {
        background: #bbb;
    }
</style>
