---
<div class="archive-legend">
    <div class="legend-header">Simbología del Archivo</div>
    <div class="legend-grid">
        <div class="legend-item">
            <span class="legend-icon">🏛️</span>
            <span class="legend-label">Nodo Central</span>
        </div>
        <div class="legend-item">
            <span class="legend-icon">🤖</span>
            <span class="legend-label">Core AI</span>
        </div>
        <div class="legend-item">
            <span class="legend-icon">🏗️</span>
            <span class="legend-label">Arquitectura</span>
        </div>
        <div class="legend-item">
            <span class="legend-icon">💻</span>
            <span class="legend-label">Desarrollo</span>
        </div>
        <div class="legend-item">
            <span class="legend-icon">🛠️</span>
            <span class="legend-label">Utilidades</span>
        </div>
        <div class="legend-item">
            <span class="legend-icon">📄</span>
            <span class="legend-label">Documento MDX</span>
        </div>
    </div>
</div>

<style>
    .archive-legend {
        background: #F9F9F9;
        border: 1px solid #DDD;
        border-radius: 4px;
        padding: 15px;
        margin-top: 20px;
    }

    .legend-header {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        color: #666;
        margin-bottom: 12px;
        border-bottom: 1px solid #EEE;
        padding-bottom: 5px;
    }

    .legend-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .legend-icon {
        font-size: 1.1rem;
    }

    .legend-label {
        font-size: 0.75rem;
        color: #444;
        font-weight: 500;
    }
</style>
