---
interface Props {
    title: string;
    version?: string;
}

const { title, version = "v1.0" } = Astro.props;
---
<div class="archive-content-header">
    <div class="title-row">
        <h1 class="content-title">{title}</h1>
        <span class="version-badge">{version}</span>
        
        <div class="action-icons">
            <button class="icon-btn" title="Add to Favorites">
                <span class="icon">⭐</span>
                <span class="btn-text">Add to Favorites</span>
            </button>
            <button class="icon-btn" title="Print" onclick="window.print()">
                <span class="icon">🖨️</span>
                <span class="btn-text">Print</span>
            </button>
            <button class="icon-btn" title="Download">
                <span class="icon">💾</span>
                <span class="btn-text">Download (TXT)</span>
            </button>
        </div>
    </div>
</div>

<style>
    .archive-content-header {
        padding-bottom: 15px;
        margin-bottom: 25px;
        border-bottom: 1px solid #ddd;
    }

    .title-row {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .content-title {
        font-size: 2.2rem;
        font-weight: 800;
        margin: 0;
        color: #111;
        letter-spacing: -0.02em;
    }

    .version-badge {
        background: #f0f0f0;
        color: #666;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: 600;
        border: 1px solid #ccc;
    }

    .action-icons {
        margin-left: auto;
        display: flex;
        gap: 12px;
    }

    .icon-btn {
        background: none;
        border: none;
        display: flex;
        align-items: center;
        gap: 5px;
        cursor: pointer;
        color: #0066CC;
        font-size: 0.85rem;
        font-weight: 500;
        padding: 4px 8px;
        border-radius: 4px;
        transition: background 0.2s;
    }

    .icon-btn:hover {
        background: #f0f7ff;
        text-decoration: underline;
    }

    .icon {
        font-size: 1.1rem;
    }

    @media (max-width: 768px) {
        .action-icons {
            margin-left: 0;
            width: 100%;
            justify-content: flex-start;
        }
        
        .btn-text {
            display: none;
        }
    }
</style>
