---
import { getCollection } from 'astro:content';

const allCheatsheets = await getCollection('cheatsheets');
const categories = [...new Set(allCheatsheets.map(post => post.id.split('/')[0]).filter(c => c !== 'welcome'))].sort();
---
<div class="sub-navbar">
    <div class="sub-nav-content">
        <nav class="secondary-nav">
            <a href="/popular" class="sub-nav-link">Popular</a>
            <a href="/new" class="sub-nav-link">New</a>
            <div class="dropdown">
                <button class="sub-nav-link dropdown-toggle">By Category ▾</button>
                <div class="dropdown-menu">
                    {categories.map(cat => (
                        <a href={`/${cat}`} class="dropdown-item">
                            {cat.charAt(0).toUpperCase() + cat.slice(1)}
                        </a>
                    ))}
                </div>
            </div>
            <a href="/language" class="sub-nav-link">By Language</a>
            <a href="/tool" class="sub-nav-link">By Tool</a>
            <a href="/submit" class="sub-nav-link highlight">Submit a Sheet</a>
        </nav>

        <div class="search-console">
            <div class="search-input-wrapper">
                <span class="search-icon">🔍</span>
                <input 
                    type="text" 
                    id="subNavbarSearch" 
                    placeholder="Search for a cheatsheet..." 
                    autocomplete="off"
                />
            </div>
            <button class="search-button">Search</button>
        </div>
    </div>
</div>

<style>
    .sub-navbar {
        background: #F8F8F8;
        border-bottom: 1px solid #CCC;
        padding: 8px 20px;
        box-shadow: inset 0 1px 0 #FFF;
    }

    .sub-nav-content {
        max-width: 1600px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .secondary-nav {
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .sub-nav-link {
        font-size: 0.85rem;
        color: #555;
        text-decoration: none;
        font-weight: 500;
        padding: 4px 8px;
        border-radius: 4px;
        transition: all 0.2s;
    }

    .sub-nav-link:hover {
        background: rgba(0,0,0,0.05);
        color: var(--color-primary);
    }

    .sub-nav-link.highlight {
        color: var(--color-primary);
        font-weight: 700;
    }

    .search-console {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .search-input-wrapper {
        position: relative;
        background: white;
        border: 1px solid #CCC;
        border-radius: 4px;
        padding: 4px 10px;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: inset 0 1px 2px rgba(0,0,0,0.1);
        width: 300px;
    }

    .search-icon {
        font-size: 0.9rem;
        opacity: 0.6;
    }

    #subNavbarSearch {
        border: none;
        outline: none;
        font-size: 0.85rem;
        width: 100%;
        color: #333;
    }

    .search-button {
        background: linear-gradient(to bottom, #FFF, #E0E0E0);
        border: 1px solid #BBB;
        padding: 4px 12px;
        font-size: 0.85rem;
        font-weight: 600;
        border-radius: 4px;
        cursor: pointer;
        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }

    .search-button:active {
        background: #DDD;
        box-shadow: inset 0 1px 2px rgba(0,0,0,0.2);
    }

    /* Dropdown simple styling */
    .dropdown {
        position: relative;
    }

    .dropdown-menu {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        background: white;
        border: 1px solid #CCC;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        border-radius: 4px;
        padding: 5px 0;
        min-width: 150px;
        z-index: 100;
    }

    .dropdown-item {
        display: block;
        padding: 8px 15px;
        color: #444;
        text-decoration: none;
        font-size: 0.8rem;
        transition: all 0.2s;
    }

    .dropdown-item:hover {
        background: var(--texture-aqua);
        color: white;
    }

    .dropdown-toggle {
        background: none;
        border: none;
        cursor: pointer;
    }
</style>
