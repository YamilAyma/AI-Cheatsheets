---
import SidebarCard from '../Shared/SidebarCard.astro';
---
<SidebarCard title="Downloads">
    <div class="download-links">
        <a href="#" class="download-item">
            <span class="file-type txt">TXT</span>
            <div class="file-info">
                <span class="file-label">Plain Text Archive</span>
                <span class="file-meta">ASCII Format • 12KB</span>
            </div>
        </a>
        <a href="#" class="download-item">
            <span class="file-type pdf">PDF</span>
            <div class="file-info">
                <span class="file-label">Standard Print PDF</span>
                <span class="file-meta">Vector Graphics • 1.2MB</span>
            </div>
        </a>
    </div>
</SidebarCard>

<style>
    .download-links {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .download-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 8px;
        text-decoration: none;
        border-radius: 6px;
        transition: background 0.2s;
    }

    .download-item:hover {
        background: rgba(0,0,0,0.03);
    }

    .file-type {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 4px;
        font-size: 0.65rem;
        font-weight: 800;
        color: white;
    }

    .file-type.txt { background: #666; }
    .file-type.pdf { background: #e74c3c; }

    .file-info {
        display: flex;
        flex-direction: column;
    }

    .file-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #333;
    }

    .file-meta {
        font-size: 0.7rem;
        color: #888;
    }
</style>
