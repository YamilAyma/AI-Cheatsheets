---
import SidebarCard from '../Shared/SidebarCard.astro';

interface Props {
    category: string;
    language: string;
    license: string;
    author: string;
    version: string;
}

const { category, language, license, author, version } = Astro.props;
---
<SidebarCard title="Details">
    <div class="metadata-grid">
        <div class="meta-row">
            <span class="meta-label">Category</span>
            <span class="meta-value">{category}</span>
        </div>
        <div class="meta-row">
            <span class="meta-label">Language</span>
            <span class="meta-value">{language}</span>
        </div>
        <div class="meta-row">
            <span class="meta-label">License</span>
            <span class="meta-value">{license}</span>
        </div>
        <div class="meta-row">
            <span class="meta-label">Author</span>
            <span class="meta-value">{author}</span>
        </div>
        <div class="meta-row">
            <span class="meta-label">Version</span>
            <span class="meta-value">{version}</span>
        </div>
    </div>
</SidebarCard>

<style>
    .metadata-grid {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .meta-row {
        display: flex;
        justify-content: space-between;
        padding-bottom: 4px;
        border-bottom: 1px dotted #eee;
    }

    .meta-row:last-child {
        border-bottom: none;
    }

    .meta-label {
        font-size: 0.75rem;
        color: #888;
        font-weight: 500;
    }

    .meta-value {
        font-size: 0.75rem;
        color: #333;
        font-weight: 700;
    }
</style>
