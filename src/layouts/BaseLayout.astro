---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	breadcrumbs?: { name: string; href: string }[];
}

const { 
	title, 
	description = "Un centro de conocimiento con resúmenes, comandos y buenas prácticas sobre programación, arquitectura y herramientas de desarrollo.",
	breadcrumbs = [{ name: 'Inicio', href: '/' }]
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'http://localhost:4321');
const socialImageURL = new URL('/default-og-image.png', Astro.url);
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} - IA Cheatsheets</title>

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={`${title} - IA Cheatsheets`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={socialImageURL} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={`${title} - IA Cheatsheets`} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={socialImageURL} />
	</head>
	<body>
		<header>
			<h1>IA Cheatsheets</h1>
			<nav class="breadcrumbs">
				{breadcrumbs.map((crumb, index) => (
					<>
						{index > 0 && " / "}
						<a href={crumb.href}>{crumb.name}</a>
					</>
				))}
			</nav>
		</header>
		<main>
			<div class="content-container">
				<slot />
			</div>
		</main>
		<footer>
			<p>Plataforma de Cheatsheets v2.0 (Astro SSG)</p>
		</footer>

		<!-- Floating Buttons logic can be added here or as a component -->
		<slot name="fab" />
	</body>
</html>
