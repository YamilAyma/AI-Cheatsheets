---
import Header from '../components/organisms/Header.astro';
import SubNavbar from '../components/organisms/SubNavbar.astro';
import Footer from '../components/organisms/Footer.astro';
import NavigationIndex from '../components/organisms/NavigationIndex.astro';
import MetadataStack from '../components/organisms/MetadataStack.astro';

import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
	breadcrumbs?: { name: string; href: string }[];
    author?: string;
    version?: string;
    updated?: string;
    slug?: string;
}

const { 
	title, 
	description = "Un centro de conocimiento con resúmenes, comandos y buenas prácticas sobre programación, arquitectura y herramientas de desarrollo.",
	breadcrumbs = [{ name: 'Home', href: '/' }],
    author,
    version,
    updated,
    slug
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'http://localhost:4321');
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | AI-Cheatsheets Archive</title>
		<link rel="canonical" href={canonicalURL} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body>
		<Header />
		<SubNavbar breadcrumbs={breadcrumbs} />
		
		<main class="holy-grail-container">
            <!-- Left Sidebar -->
			<aside class="left-sidebar">
				<NavigationIndex currentSlug={slug} />
			</aside>

            <!-- Main Content Area -->
			<div class="main-content">
				<slot />
			</div>

            <!-- Right Sidebar -->
			<aside class="right-sidebar">
				<MetadataStack 
                    author={author} 
                    version={version} 
                    updated={updated} 
                />
			</aside>
		</main>

		<Footer />
	</body>
</html>

<style is:global>
	:root {
		--sidebar-left-width: 260px;
		--sidebar-right-width: 300px;
		--max-width: 1400px;
	}

	body {
		background-color: var(--color-surface);
		margin: 0;
		padding: 0;
	}

	.holy-grail-container {
		display: grid;
		grid-template-columns: var(--sidebar-left-width) 1fr var(--sidebar-right-width);
		gap: 20px;
		max-width: var(--max-width);
		margin: 20px auto;
		padding: 0 20px;
		align-items: start;
        animation: revealUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) backwards;
	}

    .left-sidebar {
        animation: revealRight 0.6s cubic-bezier(0.22, 1, 0.36, 1) backwards;
        animation-delay: 0.1s;
    }

    .main-content {
        animation: revealUp 0.6s cubic-bezier(0.22, 1, 0.36, 1) backwards;
        animation-delay: 0.2s;
    }

    .right-sidebar {
        animation: revealLeft 0.6s cubic-bezier(0.22, 1, 0.36, 1) backwards;
        animation-delay: 0.3s;
    }

    /* Animations */
    @keyframes revealUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @keyframes revealRight {
        from { opacity: 0; transform: translateX(-20px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @keyframes revealLeft {
        from { opacity: 0; transform: translateX(20px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @media (max-width: 1200px) {
        .holy-grail-container {
            grid-template-columns: var(--sidebar-left-width) 1fr;
        }
        .right-sidebar {
            display: none;
        }
    }

    @media (max-width: 900px) {
        .holy-grail-container {
            display: flex;
            flex-direction: column;
        }
        .left-sidebar, .right-sidebar {
            width: 100%;
        }
    }
</style>
